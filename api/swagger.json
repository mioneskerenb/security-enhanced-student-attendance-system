{
  "openapi": "3.0.0",
  "info": {
    "title": "Attendance System API",
    "version": "1.0.0",
    "description": "Role-based API documentation. Admin endpoints are for the C# Administrator module. ClassTeacher endpoints are for attendance-related functions only."
  },
  "servers": [
    {
      "url": "http://localhost"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Token"
      }
    },
    "schemas": {
      "ApiMessageResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "userType": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "Id": {
                "type": "integer"
              },
              "firstName": {
                "type": "string"
              },
              "lastName": {
                "type": "string"
              },
              "emailAddress": {
                "type": "string"
              },
              "username": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "Login for Administrator and ClassTeacher"
    },
    {
      "name": "Debug",
      "description": "Token debugging"
    },
    {
      "name": "Admin - Dashboard",
      "description": "Admin dashboard statistics"
    },
    {
      "name": "Admin - Students",
      "description": "Admin can add, view, edit, delete, search students"
    },
    {
      "name": "Admin - Teachers",
      "description": "Admin can add, view, edit, delete, search teachers and assignments"
    },
    {
      "name": "Admin - Classes",
      "description": "Admin can manage classes"
    },
    {
      "name": "Admin - Class Arms",
      "description": "Admin can manage class arms"
    },
    {
      "name": "Admin - Session & Terms",
      "description": "Admin can manage session and term"
    },
    {
      "name": "ClassTeacher - Students",
      "description": "ClassTeacher can view assigned students"
    },
    {
      "name": "ClassTeacher - Attendance",
      "description": "ClassTeacher can take attendance, view attendance, reports, and student attendance"
    }
  ],
  "paths": {
    "/Student-Attendance-System01-main/api/login.php": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Login as Administrator or ClassTeacher",
        "description": "Use Administrator for the C# admin module. Use ClassTeacher for attendance module.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "test@mail.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "1234"
                  },
                  "userType": {
                    "type": "string",
                    "enum": [
                      "Administrator",
                      "ClassTeacher"
                    ],
                    "example": "Administrator"
                  }
                },
                "required": [
                  "username",
                  "password",
                  "userType"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    },
